# ════════════════════════════════════════════════════════════
# .env.example  –  Sao chép file này thành .env và điền key
# ════════════════════════════════════════════════════════════

# ── ViQAG model (Hugging Face) ─────────────────────────────
# Model mặc định (fine-tuned QAG tiếng Việt)
VIQAG_MODEL=VietAI/vit5-base-vi-qag

# HF Token (lấy tại https://huggingface.co/settings/tokens)
# Cần khi dùng HF Inference API
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM Backend: chọn MỘT trong ba ────────────────────────

# Option 1 – OpenAI (khuyến nghị cho demo nhanh)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2 – Google Gemini (miễn phí tier)
# GEMINI_API_KEY=AIxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 3 – Ollama local (cài tại https://ollama.ai)
# OLLAMA_HOST=http://localhost:11434
